PORT=8000
NODE_ENV=development

# Neon PostgreSQL Database
DATABASE_URL=postgresql://user:password@ep-your-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key
ADMIN_EMAIL=admin@kerala2026.in
ADMIN_PASSWORD=your_secure_password

# Cloudflare R2 (for photos)
CLOUDFLARE_R2_BUCKET=election2026
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY=your_access_key
CLOUDFLARE_R2_SECRET_KEY=your_secret_key
CLOUDFLARE_R2_PUBLIC_URL=https://pub-your-id.r2.dev

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=your_meili_master_key
